{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}/server",
      "python": "${workspaceFolder}/server/.venv/bin/python",
      "console": "integratedTerminal"
    },
    {
      "name": "Edge: test WAV",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/edge/main.py",
      "args": [
        "--server",
        "http://127.0.0.1:8000",
        "--wav",
        "test_cough.wav"
      ],
      "cwd": "${workspaceFolder}/edge",
      "python": "${workspaceFolder}/edge/.venv/bin/python",
      "console": "integratedTerminal"
    },
    {
      "name": "Dashboard: Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://127.0.0.1:5173",
      "webRoot": "${workspaceFolder}/dashboard/src",
      "preLaunchTask": "Dashboard: dev"
    }
  ]
}
